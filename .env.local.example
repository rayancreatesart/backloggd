# Neon Postgres (required for hosted deployment)
# Create a free database at https://neon.tech and paste the connection string here
DATABASE_URL=postgres://user:password@host/dbname

# SteamGridDB (optional — for fallback cover art)
# Get yours at https://www.steamgriddb.com/profile/preferences/api
STEAMGRIDDB_API_KEY=your_steamgriddb_api_key_here
